#!/usr/bin/env bash
set -euo pipefail

VERSION="1.0.0"
SCRIPT_NAME="evidentai"

print_help() {
    cat << 'EOF'
Usage: evidentai <command> [options]

Commands:
  validate   Validate persons.personinfo.json
  timeline   Generate risk.timeline.json
  relation   Generate persons.relation.json
  generate   Generate both timeline and relation

Options:
  -i, --input <file>    Input file (required)
  -o, --output <file>   Output file (default: risk.timeline.json or persons.relation.json)
  -v, --video-path <path>  Video path for timeline (default: raw_data/video.mp4)
  -f, --force           Overwrite without prompt
  -h, --help            Show help

Examples:
  evidentai validate -i persons.personinfo.json
  evidentai validate -i custom.json

  evidentai timeline -i persons.personinfo.json
  evidentai timeline -i persons.personinfo.json -o output/timeline.json
  evidentai timeline -i persons.personinfo.json -v raw_data/video.mp4

  evidentai relation -i persons.personinfo.json
  evidentai relation -i persons.personinfo.json -f

  evidentai generate -i persons.personinfo.json
  evidentai generate -i persons.personinfo.json -v raw_data/video.mp4
EOF
}

die() {
    echo "Error: $1" >&2
    exit 1
}

check_deps() {
    if ! command -v jq &> /dev/null; then
        die "jq is required but not installed."
    fi
    if ! command -v python3 &> /dev/null; then
        die "python3 is required but not installed."
    fi
}

validate_personinfo() {
    local input="$1"
    
    [[ ! -f "$input" ]] && die "Input file not found: $input"
    
    jq -e '.' "$input" > /dev/null 2>&1 || die "Invalid JSON format: $input"
    
    python3 << PYEOF
import json
import sys
import re

with open("$input", "r") as f:
    data = json.load(f)

errors = 0

if "version" not in data or not data["version"]:
    print("Error: missing 'version' field")
    errors += 1

persons = data.get("persons", [])
if not persons:
    print("Error: 'persons' array is empty or missing")
    errors += 1

valid_roles = {"attacker", "victim", "witness"}
placeholder_names = {"未知", "某人", "不详", "某某"}
seen_ids = set()
all_ids = {p.get("id") for p in persons if p.get("id")}

for i, person in enumerate(persons):
    pid = person.get("id")
    if not pid:
        print(f"Error: person[{i}] missing 'id' field")
        errors += 1
        continue
    
    if not re.match(r"^p_[a-zA-Z0-9_]+$", pid):
        print(f"Error: person '{pid}' has invalid id format (expected p_xxx)")
        errors += 1
    
    if pid in seen_ids:
        print(f"Error: duplicate person id '{pid}'")
        errors += 1
    seen_ids.add(pid)
    
    name = person.get("name", "")
    if not name:
        print(f"Error: person '{pid}' missing 'name' field")
        errors += 1
    elif name.strip() in placeholder_names:
        print(f"Error: person '{pid}' name '{name}' is a placeholder")
        errors += 1
    
    role = person.get("role", "")
    if not role:
        print(f"Error: person '{pid}' missing 'role' field")
        errors += 1
    elif role not in valid_roles:
        print(f"Error: person '{pid}' has invalid role '{role}' (expected: attacker, victim, witness)")
        errors += 1
    
    behaviors = person.get("behaviors", [])
    for j, behavior in enumerate(behaviors):
        time_val = behavior.get("time")
        end_time = behavior.get("endTime")
        
        if time_val is not None and end_time is not None:
            if time_val > end_time:
                print(f"Error: person '{pid}' behavior[{j}] has time > endTime")
                errors += 1
        
        for ref_id in behavior.get("personIds", []):
            if ref_id and ref_id not in all_ids:
                print(f"Error: person '{pid}' behavior[{j}] references unknown personId '{ref_id}'")
                errors += 1

if errors == 0:
    print(f"✓ Validation passed: $input")
    sys.exit(0)
else:
    print(f"✗ Validation failed with {errors} error(s)")
    sys.exit(1)
PYEOF
}

generate_timeline() {
    local input="$1"
    local output="$2"
    local force="$3"
    local video_path="$4"
    
    [[ ! -f "$input" ]] && die "Input file not found: $input"
    
    if [[ -f "$output" && "$force" != "true" ]]; then
        read -p "Output file exists: $output. Overwrite? [y/N] " -n 1 -r
        echo
        [[ ! $REPLY =~ ^[Yy]$ ]] && echo "Aborted" && return 1
    fi
    
    python3 << PYEOF
import json

with open("$input", "r") as f:
    data = json.load(f)

persons = data.get("persons", [])
segments = []
seg_id = 1

for person in persons:
    source_id = person.get("id")
    for behavior in person.get("behaviors", []):
        person_ids = behavior.get("personIds", [])
        if not person_ids:
            continue
        
        all_ids = [source_id] + person_ids
        all_ids = list(dict.fromkeys(all_ids))
        
        time_val = behavior.get("time", 0)
        end_time = behavior.get("endTime", time_val + 10)
        
        segments.append({
            "id": f"seg_{seg_id}",
            "startTime": time_val,
            "endTime": end_time,
            "description": behavior.get("action", ""),
            "personIds": all_ids
        })
        seg_id += 1

segments.sort(key=lambda x: x["startTime"])

result = {
    "version": "1.0",
    "videoPath": "$video_path",
    "segments": segments
}

with open("$output", "w") as f:
    json.dump(result, f, ensure_ascii=False, indent=2)

print(f"✓ Generated: $output")
PYEOF
}

generate_relation() {
    local input="$1"
    local output="$2"
    local force="$3"
    
    [[ ! -f "$input" ]] && die "Input file not found: $input"
    
    if [[ -f "$output" && "$force" != "true" ]]; then
        read -p "Output file exists: $output. Overwrite? [y/N] " -n 1 -r
        echo
        [[ ! $REPLY =~ ^[Yy]$ ]] && echo "Aborted" && return 1
    fi
    
    python3 << PYEOF
import json
import math

with open("$input", "r") as f:
    data = json.load(f)

persons = data.get("persons", [])

existing_layout = {}
existing_edges = []
if "$output" and __import__("os").path.exists("$output"):
    try:
        with open("$output", "r") as f:
            existing = json.load(f)
            existing_layout = existing.get("layout", {})
            existing_edges = existing.get("edges", [])
    except:
        pass

edge_map = {}
for person in persons:
    source_id = person.get("id")
    for behavior in person.get("behaviors", []):
        action = behavior.get("action", "")
        for target_id in behavior.get("personIds", []):
            if not target_id:
                continue
            key = f"{source_id}->{target_id}"
            if key not in edge_map:
                edge_map[key] = {"source": source_id, "target": target_id, "actions": []}
            if action and action not in edge_map[key]["actions"]:
                edge_map[key]["actions"].append(action)

new_auto_edges = []
for key, data in edge_map.items():
    new_auto_edges.append({
        "source": data["source"],
        "target": data["target"],
        "label": "、".join(data["actions"]),
        "edgeSource": "auto"
    })

manual_edges = [e for e in existing_edges if e.get("edgeSource") == "manual"]

max_id = 0
for e in existing_edges:
    match = __import__("re").match(r"e_(\d+)", e.get("id", ""))
    if match:
        max_id = max(max_id, int(match.group(1)))

final_edges = list(manual_edges)
for edge in new_auto_edges:
    max_id += 1
    final_edges.append({
        "id": f"e_{max_id}",
        "source": edge["source"],
        "target": edge["target"],
        "label": edge["label"],
        "edgeSource": "auto"
    })

layout = dict(existing_layout)
cols = math.ceil(math.sqrt(len(persons))) if persons else 1
for i, p in enumerate(persons):
    pid = p.get("id")
    if pid and pid not in layout:
        col = i % cols
        row = i // cols
        layout[pid] = {"x": 100 + col * 600, "y": 100 + row * 450}

existing_ids = {p.get("id") for p in persons}
layout = {k: v for k, v in layout.items() if k in existing_ids}

result = {
    "version": "1.0",
    "layout": layout,
    "edges": final_edges
}

with open("$output", "w") as f:
    json.dump(result, f, ensure_ascii=False, indent=2)

print(f"✓ Generated: $output")
PYEOF
}

check_deps

if [[ $# -lt 1 ]]; then
    print_help
    exit 1
fi

COMMAND=""
INPUT=""
OUTPUT=""
VIDEO_PATH="raw_data/video.mp4"
FORCE="false"

while [[ $# -gt 0 ]]; do
    case $1 in
        validate|timeline|relation|generate)
            COMMAND="$1"
            shift
            ;;
        -i|--input)
            INPUT="$2"
            shift 2
            ;;
        -o|--output)
            OUTPUT="$2"
            shift 2
            ;;
        -v|--video-path)
            VIDEO_PATH="$2"
            shift 2
            ;;
        -f|--force)
            FORCE="true"
            shift
            ;;
        -h|--help)
            print_help
            exit 0
            ;;
        *)
            die "Unknown option: $1"
            ;;
    esac
done

[[ -z "$COMMAND" ]] && die "Command is required"
[[ -z "$INPUT" ]] && die "Input file is required (-i, --input)"

case $COMMAND in
    validate)
        validate_personinfo "$INPUT"
        ;;
    timeline)
        OUTPUT="${OUTPUT:-risk.timeline.json}"
        generate_timeline "$INPUT" "$OUTPUT" "$FORCE" "$VIDEO_PATH"
        ;;
    relation)
        OUTPUT="${OUTPUT:-persons.relation.json}"
        generate_relation "$INPUT" "$OUTPUT" "$FORCE"
        ;;
    generate)
        generate_timeline "$INPUT" "risk.timeline.json" "$FORCE" "$VIDEO_PATH"
        generate_relation "$INPUT" "persons.relation.json" "$FORCE"
        ;;
esac
