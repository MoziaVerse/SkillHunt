#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
YOLO_VENDOR_ROOT="$SCRIPT_DIR/_vendor"
YOLO_SRC="$YOLO_VENDOR_ROOT/src"
YOLO_PYTHON_VENDOR="$YOLO_VENDOR_ROOT/python"

if command -v python3 >/dev/null 2>&1; then
  export PYTHONPATH="$YOLO_PYTHON_VENDOR:$YOLO_SRC${PYTHONPATH:+:$PYTHONPATH}"
  exec python3 -m yolo_cli.cli "$@"
fi

echo "Error: unable to run bundled yolo-cli." >&2
echo "Expected python3 plus vendored sources under:" >&2
echo "  $YOLO_SRC" >&2
echo "  $YOLO_PYTHON_VENDOR" >&2
exit 1
