#!/usr/bin/env bash
set -euo pipefail

print_help() {
  cat <<'EOF'
Usage: extract-analysis-clip --input <video> --start <seconds> [--duration <seconds> | --end <seconds>] --output <clip.mp4> [options]

Required:
  --input <path>         Source video path
  --start <seconds>      Source-video start time in seconds
  --output <path>        Output clip path

Duration options:
  --duration <seconds>   Clip duration in seconds
  --end <seconds>        Source-video end time in seconds

Optional:
  --scale <expr>         ffmpeg scale expr (default: 640:-1)
  --fps <value>          Output fps (optional)
  --notes <text>         Notes stored in sidecar JSON
  --force                Overwrite output files
  -h, --help             Show help

Sidecar naming:
  If output is analysis/conflict_clip.mp4, sidecar will be:
  analysis/conflict_clip.clip.json
EOF
}

die() {
  echo "Error: $1" >&2
  exit 1
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required but not installed"
}

INPUT=""
START=""
DURATION=""
END_TIME=""
OUTPUT=""
SCALE="640:-1"
FPS=""
NOTES=""
FORCE="false"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --input)
      INPUT="${2:-}"
      shift 2
      ;;
    --start)
      START="${2:-}"
      shift 2
      ;;
    --duration)
      DURATION="${2:-}"
      shift 2
      ;;
    --end)
      END_TIME="${2:-}"
      shift 2
      ;;
    --output)
      OUTPUT="${2:-}"
      shift 2
      ;;
    --scale)
      SCALE="${2:-}"
      shift 2
      ;;
    --fps)
      FPS="${2:-}"
      shift 2
      ;;
    --notes)
      NOTES="${2:-}"
      shift 2
      ;;
    --force)
      FORCE="true"
      shift
      ;;
    -h|--help)
      print_help
      exit 0
      ;;
    *)
      die "Unknown argument: $1"
      ;;
  esac
done

require_cmd ffmpeg
require_cmd ffprobe
require_cmd python3

[[ -n "$INPUT" ]] || die "--input is required"
[[ -f "$INPUT" ]] || die "Input file not found: $INPUT"
[[ -n "$START" ]] || die "--start is required"
[[ -n "$OUTPUT" ]] || die "--output is required"

if [[ -z "$DURATION" && -z "$END_TIME" ]]; then
  die "Either --duration or --end is required"
fi

if [[ -n "$DURATION" && -n "$END_TIME" ]]; then
  die "Use either --duration or --end, not both"
fi

if [[ -n "$END_TIME" ]]; then
  DURATION="$(python3 - <<PY
start = float("$START")
end = float("$END_TIME")
if end <= start:
    raise SystemExit(1)
print(end - start)
PY
)" || die "--end must be greater than --start"
fi

mkdir -p "$(dirname "$OUTPUT")"

SIDECAR="${OUTPUT%.*}.clip.json"

if [[ -f "$OUTPUT" && "$FORCE" != "true" ]]; then
  die "Output clip already exists: $OUTPUT (use --force to overwrite)"
fi

if [[ -f "$SIDECAR" && "$FORCE" != "true" ]]; then
  die "Output sidecar already exists: $SIDECAR (use --force to overwrite)"
fi

VIDEO_FPS="$(ffprobe -v quiet -select_streams v:0 -show_entries stream=r_frame_rate -of csv=p=0 "$INPUT")"

SOURCE_START_FRAME="$(python3 - <<PY
from fractions import Fraction
fps = float(Fraction("$VIDEO_FPS"))
start = float("$START")
print(int(round(start * fps)))
PY
)"

VF_CHAIN="scale=${SCALE}"
if [[ -n "$FPS" ]]; then
  VF_CHAIN="${VF_CHAIN},fps=${FPS}"
fi

FFMPEG_ARGS=(-y)
if [[ "$FORCE" != "true" ]]; then
  FFMPEG_ARGS=(-n)
fi

ffmpeg "${FFMPEG_ARGS[@]}" \
  -ss "$START" \
  -i "$INPUT" \
  -t "$DURATION" \
  -vf "$VF_CHAIN" \
  -c:v libx264 \
  -preset fast \
  -c:a aac \
  -movflags +faststart \
  "$OUTPUT" >/dev/null 2>&1 || die "ffmpeg failed while creating clip"

CLIP_DURATION="$(ffprobe -v quiet -show_entries format=duration -of csv=p=0 "$OUTPUT")"
SOURCE_END_TIME="$(python3 - <<PY
start = float("$START")
duration = float("$CLIP_DURATION")
print(round(start + duration, 6))
PY
)"

python3 - <<PY
import json

data = {
    "source_video_path": "$INPUT",
    "clip_path": "$OUTPUT",
    "source_start_time": float("$START"),
    "source_end_time": float("$SOURCE_END_TIME"),
    "clip_duration": float("$CLIP_DURATION"),
    "source_start_frame": int("$SOURCE_START_FRAME"),
    "notes": "$NOTES",
}

with open("$SIDECAR", "w", encoding="utf-8") as f:
    json.dump(data, f, ensure_ascii=False, indent=2)
    f.write("\n")
PY

echo "✓ Generated clip: $OUTPUT"
echo "✓ Generated sidecar: $SIDECAR"
