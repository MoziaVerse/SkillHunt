#!/usr/bin/env python3
"""Validate candidate/event-window coverage for video-person-analysis outputs."""

from __future__ import annotations

import argparse
import json
import re
import sys
from pathlib import Path
from typing import Any


TOLERANCE_SECONDS = 0.75


def load_json(path: Path) -> Any:
    try:
        with path.open("r", encoding="utf-8") as f:
            return json.load(f)
    except FileNotFoundError:
        raise SystemExit(f"Missing required file: {path}")
    except json.JSONDecodeError as exc:
        raise SystemExit(f"Invalid JSON in {path}: {exc}") from exc


def as_float(value: Any, label: str) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        raise ValueError(f"{label} must be a number, got {value!r}")


def merge_intervals(intervals: list[tuple[float, float]]) -> list[tuple[float, float]]:
    valid = sorted((s, e) for s, e in intervals if e > s)
    if not valid:
        return []

    merged: list[tuple[float, float]] = [valid[0]]
    for start, end in valid[1:]:
        last_start, last_end = merged[-1]
        if start <= last_end + TOLERANCE_SECONDS:
            merged[-1] = (last_start, max(last_end, end))
        else:
            merged.append((start, end))
    return merged


def gaps_within(
    start: float,
    end: float,
    intervals: list[tuple[float, float]],
) -> list[tuple[float, float]]:
    cursor = start
    gaps: list[tuple[float, float]] = []
    for interval_start, interval_end in merge_intervals(intervals):
        if interval_end <= start + TOLERANCE_SECONDS:
            continue
        if interval_start >= end - TOLERANCE_SECONDS:
            break
        if interval_start > cursor + TOLERANCE_SECONDS:
            gaps.append((cursor, min(interval_start, end)))
        cursor = max(cursor, interval_end)
    if cursor < end - TOLERANCE_SECONDS:
        gaps.append((cursor, end))
    return gaps


def basename_interval(path: str) -> tuple[float, float] | None:
    stem = Path(path).stem
    match = re.search(r"(?:^|_)(\d+(?:\.\d+)?)_(\d+(?:\.\d+)?)(?:$|_)", stem)
    if not match:
        return None
    start = float(match.group(1))
    end = float(match.group(2))
    if end <= start:
        return None
    return start, end


def sidecar_path(case_dir: Path, clip_path: str) -> Path:
    clip = case_dir / clip_path
    return clip.with_suffix(".clip.json")


def range_covers(
    start: float,
    end: float,
    spans: list[tuple[float, float]],
) -> bool:
    return not gaps_within(start, end, spans)


def explicit_gap_spans(candidate: dict[str, Any]) -> list[tuple[float, float]]:
    spans: list[tuple[float, float]] = []
    for key in ("coverage_gaps", "downgraded_spans", "excluded_subspans"):
        for item in candidate.get(key, []) or []:
            if not isinstance(item, dict):
                continue
            reason = item.get("reason") or item.get("closure_reason")
            closure = item.get("closure")
            if closure not in {None, "downgraded", "excluded"}:
                continue
            if not reason:
                continue
            try:
                spans.append((as_float(item.get("start"), f"{key}.start"), as_float(item.get("end"), f"{key}.end")))
            except ValueError:
                continue
    return spans


def documented_gap_spans(discovery: dict[str, Any]) -> list[tuple[float, float]]:
    spans: list[tuple[float, float]] = []

    for item in discovery.get("excluded_spans", []) or []:
        if not isinstance(item, dict) or not item.get("reason"):
            continue
        try:
            spans.append((as_float(item.get("start"), "excluded_spans.start"), as_float(item.get("end"), "excluded_spans.end")))
        except ValueError:
            continue

    for item in discovery.get("candidate_spans", []) or []:
        if not isinstance(item, dict):
            continue
        if item.get("closure") not in {"downgraded", "excluded"} or not (item.get("reason") or item.get("closure_reason")):
            spans.extend(explicit_gap_spans(item))
            continue
        try:
            spans.append((as_float(item.get("start"), "candidate_spans.start"), as_float(item.get("end"), "candidate_spans.end")))
        except ValueError:
            continue
        spans.extend(explicit_gap_spans(item))

    boundary = discovery.get("start_boundary_review") or {}
    for item in boundary.get("gap_explanations", []) or []:
        if not isinstance(item, dict) or not item.get("reason"):
            continue
        if item.get("closure") not in {"downgraded", "excluded"}:
            continue
        try:
            spans.append((as_float(item.get("start"), "gap_explanations.start"), as_float(item.get("end"), "gap_explanations.end")))
        except ValueError:
            continue

    return spans


def validate_clip_alignment(case_dir: Path, windows: list[dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    for window in windows:
        window_id = window.get("id", "<unknown>")
        clip_path = window.get("clip_path")
        if not clip_path:
            errors.append(f"{window_id}: missing clip_path")
            continue

        try:
            source_start = as_float(window.get("source_start_time"), f"{window_id}.source_start_time")
            source_end = as_float(window.get("source_end_time"), f"{window_id}.source_end_time")
        except ValueError as exc:
            errors.append(str(exc))
            continue

        if source_end <= source_start:
            errors.append(f"{window_id}: source_end_time must be greater than source_start_time")
            continue

        checked_anchor = False

        sidecar = sidecar_path(case_dir, clip_path)
        if sidecar.exists():
            checked_anchor = True
            data = load_json(sidecar)
            try:
                sidecar_start = as_float(data.get("source_start_time"), f"{sidecar}.source_start_time")
                sidecar_end = as_float(data.get("source_end_time"), f"{sidecar}.source_end_time")
            except ValueError as exc:
                errors.append(str(exc))
            else:
                if abs(source_start - sidecar_start) > TOLERANCE_SECONDS or abs(source_end - sidecar_end) > TOLERANCE_SECONDS:
                    errors.append(
                        f"{window_id}: source time {source_start:g}-{source_end:g} does not match sidecar "
                        f"{sidecar_start:g}-{sidecar_end:g} ({sidecar})"
                    )

        name_interval = basename_interval(clip_path)
        if name_interval is not None:
            checked_anchor = True
            name_start, name_end = name_interval
            if abs(source_start - name_start) > TOLERANCE_SECONDS or abs(source_end - name_end) > TOLERANCE_SECONDS:
                errors.append(
                    f"{window_id}: source time {source_start:g}-{source_end:g} does not match clip filename "
                    f"{name_start:g}-{name_end:g} ({clip_path})"
                )

        if not checked_anchor:
            errors.append(
                f"{window_id}: clip_path has no .clip.json sidecar and no parseable time range in filename; "
                "cannot use this event window for closure"
            )

    return errors


def validate_start_boundary(discovery: dict[str, Any], windows: list[dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    boundary = discovery.get("start_boundary_review")
    if not boundary or boundary.get("selected_start") is None or not windows:
        return errors

    try:
        selected_start = as_float(boundary.get("selected_start"), "start_boundary_review.selected_start")
        first_event_start = min(as_float(w.get("source_start_time"), f"{w.get('id', '<unknown>')}.source_start_time") for w in windows)
    except ValueError as exc:
        return [str(exc)]

    if selected_start + TOLERANCE_SECONDS >= first_event_start:
        return errors

    explained = documented_gap_spans(discovery)
    if not range_covers(selected_start, first_event_start, explained):
        errors.append(
            "start_boundary_review.selected_start is earlier than the first event window "
            f"({selected_start:g} < {first_event_start:g}), but the gap is not explicitly downgraded/excluded "
            "in candidate_discovery.json"
        )
    return errors


def validate_high_candidate_coverage(discovery: dict[str, Any], windows_by_id: dict[str, dict[str, Any]]) -> list[str]:
    errors: list[str] = []
    for candidate in discovery.get("candidate_spans", []) or []:
        if not isinstance(candidate, dict):
            continue
        if candidate.get("priority") != "high" or candidate.get("closure") != "covered_by_event_windows":
            continue

        candidate_id = candidate.get("id", "<unknown>")
        try:
            start = as_float(candidate.get("start"), f"{candidate_id}.start")
            end = as_float(candidate.get("end"), f"{candidate_id}.end")
        except ValueError as exc:
            errors.append(str(exc))
            continue

        intervals: list[tuple[float, float]] = []
        for event_id in candidate.get("event_window_ids", []) or []:
            window = windows_by_id.get(event_id)
            if not window:
                errors.append(f"{candidate_id}: event_window_ids references missing window {event_id!r}")
                continue
            try:
                intervals.append(
                    (
                        as_float(window.get("source_start_time"), f"{event_id}.source_start_time"),
                        as_float(window.get("source_end_time"), f"{event_id}.source_end_time"),
                    )
                )
            except ValueError as exc:
                errors.append(str(exc))

        gaps = gaps_within(start, end, intervals)
        if gaps:
            gap_text = ", ".join(f"{s:g}-{e:g}" for s, e in gaps)
            errors.append(
                f"{candidate_id}: high-priority candidate {start:g}-{end:g} is marked covered_by_event_windows "
                f"but has uncovered gap(s): {gap_text}"
            )
    return errors


def main() -> int:
    parser = argparse.ArgumentParser(description="Validate video-person-analysis coverage closure.")
    parser.add_argument("--case-dir", default=".", help="Case directory containing analysis/ and final JSON files")
    args = parser.parse_args()

    case_dir = Path(args.case_dir).resolve()
    discovery = load_json(case_dir / "analysis" / "candidate_discovery.json")
    event_data = load_json(case_dir / "analysis" / "event_windows.json")
    windows = event_data.get("windows", [])
    if not isinstance(windows, list) or not windows:
        print("Error: analysis/event_windows.json has no windows", file=sys.stderr)
        return 1

    windows_by_id = {window.get("id"): window for window in windows if isinstance(window, dict)}

    errors: list[str] = []
    errors.extend(validate_clip_alignment(case_dir, windows))
    errors.extend(validate_start_boundary(discovery, windows))
    errors.extend(validate_high_candidate_coverage(discovery, windows_by_id))

    if errors:
        print("Coverage validation failed:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1

    print("Coverage validation passed.")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
