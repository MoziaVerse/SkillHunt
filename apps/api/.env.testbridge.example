# Local SkillHunt api → test-server upstreams (PG + mozia-sso).
#
# Prereq:
#   1. ~/.matrix-bridge/ set up (see ~/.matrix-bridge/README.md)
#   2. SSH tunnel up: `source ~/.matrix-bridge/env.sh && mtx_tunnel_start`
#   3. `cp apps/api/.env.testbridge.example apps/api/.env.testbridge` + fill secrets
#
# Run with: `pnpm dev:bridge` (or `bun --env-file=.env.testbridge src/index.ts`)
#
# Writes go to the test-server DB — coordinate with team before destructive ops.

PORT=3333
NODE_ENV=development

# PG via tunnel: localhost:15432 -> server:36915 -> postgres-dev:5432
# Uses mozia_skillhub (write user) so local dev has full CRUD on the remote DB
# that the deployed SkillHunt will also use.
DATABASE_URL=postgresql://mozia_skillhub:skillhub%40mozia@127.0.0.1:15432/mozia_skillhub_db

# ─── auth (mozia-sso test server, already registered) ────────────────
OIDC_ISSUER=http://116.136.189.21:8778
OIDC_CLIENT_ID=642893fc13dc58d24a14
OIDC_CLIENT_SECRET=<from `mtx_psql sso -c "SELECT client_secret FROM application WHERE name='mozia-skills-hub'"`>
OIDC_PROVIDER_ID=mozia-skills-hub

BETTER_AUTH_URL=http://localhost:3333
# Generate a distinct secret for the bridge profile: `openssl rand -hex 32`
BETTER_AUTH_SECRET=<openssl rand -hex 32>

# Vite dev (5180) + anything else you want allowlisted.
TRUSTED_ORIGINS=http://localhost:5180

# ─── spec 04 · matrix S2S service auth ───────────────────────────────
# Distinct from the deployed service token; for local bridge experiments.
SKILLHUB_SERVICE_TOKEN=<openssl rand -hex 32>

# ─── OSS 视频上传 ─────────────────────────────────────────────────────
S3_ENDPOINT=https://oss.mzsjai.com
S3_PUBLIC_URL=https://oss.mzsjai.com
S3_BUCKET=skillhunt-videos
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=skillhunt
S3_SECRET_ACCESS_KEY=<from /home/devuser/seaweedfs/config/s3.env>
