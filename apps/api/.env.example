PORT=3333
DATABASE_URL=./data/skillhub.sqlite

# ─── Phase 1 · auth ──────────────────────────────────────────────────
# OIDC against mozia-sso (Casdoor).
# IMPORTANT: the registered redirect URI in mozia-sso must be exactly
# `<BETTER_AUTH_URL>/api/auth/oauth2/callback/<OIDC_PROVIDER_ID>`
OIDC_ISSUER=http://localhost:8778
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# providerId controls our callback URL slug. Defaults to `mozia-sso`. Set this
# to whatever the SSO admin actually whitelisted (e.g. their application name).
OIDC_PROVIDER_ID=mozia-sso

# better-auth: shared secret for cookie signing. Generate with `openssl rand -hex 32`.
BETTER_AUTH_URL=http://localhost:3333
BETTER_AUTH_SECRET=

# Extra trusted browser origins (comma-separated). The api auto-trusts
# BETTER_AUTH_URL and http://localhost:5180; add prod domains here.
# TRUSTED_ORIGINS=https://skillhub.mzsjai.com,https://matrix.mzsjai.com,http://localhost:5173

# ─── Phase 2 spec 04 · matrix embed (S2S service auth) ───────────────
# Long-lived secret for trusted internal services (currently: matrix
# backend). Callers send `Authorization: Bearer $SKILLHUB_SERVICE_TOKEN`
# + `X-SSO-SUB: <user-sso-sub>` to act as that user. Generate with
# `openssl rand -hex 32` and share with matrix team via secret manager,
# never IM. Leave blank to disable the S2S path entirely.
SKILLHUB_SERVICE_TOKEN=
