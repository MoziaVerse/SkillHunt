PORT=3333
DATABASE_URL=./data/skillhub.sqlite

# ─── Phase 1 · auth ──────────────────────────────────────────────────
# OIDC against mozia-sso (Casdoor).
# IMPORTANT: the registered redirect URI in mozia-sso must be exactly
# `<BETTER_AUTH_URL>/api/auth/oauth2/callback/<OIDC_PROVIDER_ID>`
OIDC_ISSUER=http://localhost:8778
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
# providerId controls our callback URL slug. Defaults to `mozia-sso`. Set this
# to whatever the SSO admin actually whitelisted (e.g. their application name).
OIDC_PROVIDER_ID=mozia-sso

# Canonical identity issuer used for external_identities. Keep this at the
# Casdoor base issuer so tokens from app-specific issuers still map to one user.
SKILLHUNT_SSO_IDENTITY_ISSUER=http://localhost:8778

# OIDC bearer verification. Leave audience empty when accepting first-party app
# tokens such as mospace; SkillHunt will decide permissions from trusted clients.
# SKILLHUNT_OIDC_ISSUER=http://localhost:8778
# SKILLHUNT_OIDC_AUDIENCE=

# First-party clients that may represent a Casdoor user when calling SkillHunt.
# Default mapped scopes for listed ids are:
# profile:read, skills:read, skills:read_private, skills:files:read
# For per-client scopes, use SKILLHUNT_TRUSTED_FIRST_PARTY_CLIENTS JSON instead.
# SKILLHUNT_TRUSTED_FIRST_PARTY_CLIENT_IDS=mospace-client-id
# SKILLHUNT_TRUSTED_FIRST_PARTY_CLIENTS=[{"clientId":"mospace-client-id","scopes":["profile:read","skills:read","skills:read_private","skills:files:read"]}]

# better-auth: shared secret for cookie signing. Generate with `openssl rand -hex 32`.
BETTER_AUTH_URL=http://localhost:3333
BETTER_AUTH_SECRET=

# Extra trusted browser origins (comma-separated). The api auto-trusts
# BETTER_AUTH_URL and http://localhost:5180; add prod domains here.
# TRUSTED_ORIGINS=https://skillhunt.mzsjai.com,https://matrix.mzsjai.com,http://localhost:5173

# ─── Phase 2 spec 04 · matrix embed (S2S service auth) ───────────────
# Long-lived secret for trusted internal services (currently: matrix
# backend). Callers send `Authorization: Bearer $SKILLHUB_SERVICE_TOKEN`
# + `X-SSO-SUB: <user-sso-sub>` to act as that user. Generate with
# `openssl rand -hex 32` and share with matrix team via secret manager,
# never IM. Leave blank to disable the S2S path entirely.
SKILLHUB_SERVICE_TOKEN=

# ─── Open API · user bearer tokens (pre-OAuth bridge) ────────────────
# Optional JSON array. Lets trusted external apps call the same /api as a
# scoped user actor before full OAuth is wired.
# Example:
# SKILLHUNT_ACCESS_TOKENS=[{"token":"dev-token","userId":"user-id","clientId":"local-app","scopes":["profile:read","skills:read","skills:read_private","skills:files:read"]}]
SKILLHUNT_ACCESS_TOKENS=

# ─── OSS 视频上传 ─────────────────────────────────────────────────────
# S3-compatible object storage for publish-page demo videos.
# Local self-hosted example:
#   S3_ENDPOINT=https://oss.mzsjai.com
#   S3_PUBLIC_URL=https://oss.mzsjai.com
#   S3_BUCKET=skillhunt-videos
#   S3_REGION=us-east-1
#   S3_ACCESS_KEY_ID=skillhunt
#   S3_SECRET_ACCESS_KEY=...
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
