# Template for apps/api/.env.test (gitignored).
# Bun loads this via --env-file. Tests delete tables freely — pointing at a
# separate SQLite file keeps dev data safe.
PORT=3333
DATABASE_URL=./data/skillhub.test.sqlite

# OIDC / better-auth left empty: auth.ts has graceful fallbacks under
# NODE_ENV=test so tests don't need real SSO config.
